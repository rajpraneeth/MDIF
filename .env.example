# MDIF environment configuration (PROJECT_SPEC §13). Copy to .env and adjust.

# Shared / environment scoping
ENVIRONMENT_ID=00000000-0000-0000-0000-000000000000
ENVIRONMENT_NAME=dev                  # dev | staging | prod

# Postgres (consumed by docker-compose)
POSTGRES_USER=mdif
POSTGRES_PASSWORD=mdif
POSTGRES_DB=mdif

# Backend
DATABASE_URL=postgresql+asyncpg://mdif:mdif@localhost:5432/mdif
JWT_SECRET=change-me-minimum-32-chars-please-override
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173

# ADF (optional, for real ADF engine)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Databricks (optional, for real Databricks engine)
DATABRICKS_TOKEN=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_ENVIRONMENT_NAME=dev
VITE_ENVIRONMENT_COLOR=yellow          # yellow | red | green
